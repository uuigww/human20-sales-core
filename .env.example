# ============================================================================
#  Human20 Sales Core — пример переменных окружения
#  Скопируй в .env:   cp .env.example .env   и заполни значения.
#  ⚠️ .env в .gitignore и НЕ коммитится. Никогда не вставляй реальные ключи
#     в чат, в код или в .env.example — только в локальный .env.
#
#  Что нужно для разных команд:
#    npm run smoke      — НИЧЕГО (оффлайн, на mock-провайдере)
#    npm run typecheck  — НИЧЕГО
#    npm run chat       — ключ LLM (блок 1)
#    npm run eval       — ключ LLM (блок 1)
#    npm run ingest     — ключ LLM (блок 1) + DATABASE_URL (блок 3)
# ============================================================================


# ----------------------------------------------------------------------------
# 1. КЛЮЧ LLM — достаточно ОДНОГО из двух вариантов (A или B).
# ----------------------------------------------------------------------------

# Вариант A (простой, рекомендуется для старта): прямой ключ OpenAI.
#   - Работает с моделями вида openai/* (дефолт продажника — openai/gpt-5-mini).
#   - Где взять: https://platform.openai.com/api-keys
#   - Этим же ключом считаются эмбеддинги для RAG (npm run ingest).
OPENAI_API_KEY=

# Вариант B (любой провайдер): ключ Vercel AI Gateway.
#   - Даёт доступ к моделям ВСЕХ провайдеров по строке "creator/model"
#     (openai/*, google/*, deepseek/*, anthropic/* и т.д.) через единый ключ.
#   - Если задан — ИМЕЕТ ПРИОРИТЕТ над OPENAI_API_KEY (роутинг идёт через gateway).
#   - Где взять: https://vercel.com/docs/ai-gateway
#   - Плюс: оплата идёт через Vercel, региональные ограничения провайдеров не мешают.
AI_GATEWAY_API_KEY=


# ----------------------------------------------------------------------------
# 2. ВЫБОР МОДЕЛЕЙ (необязательно — есть дефолты в config/models.ts).
#    Сила продажника зашита в playbook/guardrails, модель — сменный «движок».
# ----------------------------------------------------------------------------

# Модель «мозга» продаж. Пусто → дефолт openai/gpt-5-mini (~$0.25/$2.00 за 1M токенов).
# Альтернативы (цены ≈ за 1M in/out):
#   google/gemini-2.5-flash        ~$0.30/$2.50  — та же лига, огромный контекст
#   deepseek/deepseek-v4           ~$0.14 in     — ультра-дёшево; ОБЯЗАТЕЛЬНО прогнать npm run eval
#   google/gemini-2.5-flash-lite   ~$0.10/$0.40  — для огромного объёма простых диалогов
#   anthropic/claude-sonnet-4-6    ~$3/$15       — максимум качества (дорого)
# Примечание: модели не-openai/* работают только при заданном AI_GATEWAY_API_KEY (вариант B).
SALES_MODEL=

# Модель LLM-судьи для npm run eval. Пусто → берётся SALES_MODEL.
# Можно поставить дешевле/другого провайдера для независимой оценки.
JUDGE_MODEL=


# ----------------------------------------------------------------------------
# 3. БАЗА ДАННЫХ (только для прода: память клиентов + RAG-знания).
#    В dev память хранит JsonFileStore (./data) — БД не нужна.
# ----------------------------------------------------------------------------

# Postgres с расширением pgvector. Используется PostgresStore (лиды/скоринг)
# и knowledge_chunks (RAG-эмбеддинги).
#   Формат: postgres://USER:PASSWORD@HOST:PORT/DBNAME
#   Перед первым запуском применить схему:  psql "$DATABASE_URL" -f db/schema.sql
#   Затем проиндексировать знания:          npm run ingest
DATABASE_URL=
