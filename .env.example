# --- Ключ LLM: достаточно ОДНОГО из двух вариантов ниже ---

# Вариант A (простой): прямой ключ OpenAI. Работает с моделями openai/* (дефолт openai/gpt-5-mini).
# ⚠️ Никогда не вставляй ключ в чат/код — только сюда. Этот файл в .gitignore.
OPENAI_API_KEY=

# Вариант B (любой провайдер): ключ Vercel AI Gateway — модели всех провайдеров по строке "creator/model".
# Если задан — имеет приоритет. Получить: https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Какая модель питает «мозг» продаж. Меняется без правок кода.
# Дефолт без Claude: openai/gpt-5-mini. Альтернативы:
#   google/gemini-2.5-flash · deepseek/deepseek-v4 · google/gemini-2.5-flash-lite · anthropic/claude-sonnet-4-6
# Дефолт (если пусто) задан в config/models.ts.
SALES_MODEL=
# Отдельная (более дешёвая) модель для LLM-судьи в eval. Если пусто — берётся SALES_MODEL.
JUDGE_MODEL=
